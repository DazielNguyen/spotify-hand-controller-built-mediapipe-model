   "source": [
    "# Full Training Pipeline - Hand Pose Estimation Model (macOS/Windows CPU/GPU)\n",
    "\n",
    "Notebook này hỗ trợ cả macOS (Apple Silicon/Metal) và Windows (GPU NVIDIA).\n",
    "\n",
    "**Yêu cầu:**\n",
    "- macOS: Python 3.10+ với TensorFlow-metal (M1/M2/M3) hoặc TensorFlow CPU\n",
    "- Windows: Python 3.10+ với TensorFlow + CUDA\n",
    "\n",
    "**Mục tiêu tối ưu:**\n",
    "- Bật Mixed Precision nếu có GPU hỗ trợ (Apple Metal hoặc NVIDIA Tensor Cores)\n",
    "- Bật XLA JIT để tăng tốc kernel\n",
    "- Dùng train step chạy trong TensorFlow graph\n",
    "- Thanh theo dõi tiến độ trực quan\n",
    "\n",
    "**Cấu hình mặc định cho macOS (CPU):**\n",
    "- Backbone: MobileNetV3Small\n",
    "- Batch Size: 8-16 (tùy RAM)\n",
    "- Learning Rate: 1e-3 + Exponential Decay\n",
    "- Epochs: 60+\n",
    "- Checkpoint: best + periodic"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "6fd0e1f9",
   "metadata": {},
   "source": [
    "## 1. Check Required Libraries"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "f46f5132",
   "metadata": {},
   "outputs": [],
   "source": [
    "from importlib import metadata as importlib_metadata\n",
    "import importlib.util\n",
    "import subprocess\n",
    "import sys\n",
    "import platform\n",
    "\n",
    "print(\"Python:\", sys.version)\n",
    "print(\"Platform:\", platform.system(), platform.machine())\n",
    "\n",
    "# TensorFlow version - macOS có thể dùng tensorflow-metal hoặc tensorflow-cpu\n",
    "EXPECTED_TF_SPEC = \">=2.15.0,<2.17\"\n",
    "UPGRADE_PIP_TOOLS = False  # Keep False for faster reruns\n",
    "\n",
    "if UPGRADE_PIP_TOOLS:\n",
    "    subprocess.check_call([sys.executable, \"-m\", \"pip\", \"install\", \"-U\", \"pip\", \"setuptools\", \"wheel\"])\n",
    "\n",
    "try:\n",
    "    from packaging.specifiers import SpecifierSet\n",
    "    from packaging.version import Version\n",
    "    HAS_PACKAGING = True\n",
    "except Exception:\n",
    "    HAS_PACKAGING = False\n",
    "\n",
    "# macOS dùng opencv-python-headless để tránh GUI issues\n",
    "IS_MAC = platform.system() == \"Darwin\"\n",
    "cv2_package = \"opencv-python-headless\" if IS_MAC else \"opencv-python\"\n",
    "\n",
    "REQUIRED_PACKAGES = [\n",
    "    (\"numpy>=1.24.0,<2.0.0\", \"numpy\", \"numpy\", \">=1.24.0,<2.0.0\"),\n",
    "    (\"scipy>=1.10.0\", \"scipy\", \"scipy\", \">=1.10.0\"),\n",
    "    (\"pillow>=9.5.0\", \"pillow\", \"PIL\", \">=9.5.0\"),\n",
    "    (f\"{cv2_package}>=4.9.0.80\", cv2_package, \"cv2\", \">=4.9.0.80\"),\n",
    "    (\"tensorboard>=2.15.0\", \"tensorboard\", \"tensorboard\", \">=2.15.0\"),\n",
    "    (\"tqdm>=4.65.0\", \"tqdm\", \"tqdm\", \">=4.65.0\"),\n",
    "]\n",
    "\n",
    "def has_module(module_name):\n",
    "    return importlib.util.find_spec(module_name) is not None\n",
    "\n",
    "def get_dist_version(dist_name):\n",
    "    try:\n",
    "        return importlib_metadata.version(dist_name)\n",
    "    except importlib_metadata.PackageNotFoundError:\n",
    "        return None\n",
    "\n",
    "def should_install(dist_name, module_name=None, specifier=None):\n",
    "    module_name = module_name or dist_name.replace(\"-\", \"_\")\n",
    "    dist_version = get_dist_version(dist_name)\n",
    "\n",
    "    if dist_version is None:\n",
    "        return True, f\"distribution '{dist_name}' not installed\"\n",
    "\n",
    "    if specifier and HAS_PACKAGING:\n",
    "        if Version(dist_version) not in SpecifierSet(specifier):\n",
    "            return True, f\"{dist_name}=={dist_version} does not satisfy {specifier}\"\n",
    "\n",
    "    if not has_module(module_name):\n",
    "        return True, f\"module '{module_name}' cannot be imported\"\n",
    "\n",
    "    return False, f\"{dist_name}=={dist_version} already satisfies requirements\"\n",
    "\n",
    "def ensure_package(requirement, dist_name, module_name=None, specifier=None):\n",
    "    need_install, reason = should_install(dist_name, module_name, specifier)\n",
    "    if need_install:\n",
    "        print(f\"  - install {requirement} ({reason})\")\n",
    "        subprocess.check_call([sys.executable, \"-m\", \"pip\", \"install\", requirement])\n",
    "    else:\n",
    "        print(f\"  - skip {requirement} ({reason})\")\n",
    "\n",
    "if not has_module(\"tensorflow\"):\n",
    "    raise RuntimeError(\n",
    "        \"TensorFlow chưa có trong kernel hiện tại.\\n\"\n",
    "        \"Để cài đặt:\\n\"\n",
    "        \"  - macOS (Apple Silicon): pip install tensorflow-metal\\n\"\n",
    "        \"  - macOS (Intel): pip install tensorflow\\n\"\n",
    "        \"  - Windows: pip install tensorflow\"\n",
    "    )\n",
    "\n",
    "tf_version = get_dist_version(\"tensorflow\")\n",
    "print(f\"Detected TensorFlow: {tf_version}\")\n",
    "if HAS_PACKAGING and tf_version is not None:\n",
    "    if Version(tf_version) not in SpecifierSet(EXPECTED_TF_SPEC):\n",
    "        print(f\"Warning: TensorFlow version khuyến nghị là {EXPECTED_TF_SPEC}, hiện tại là {tf_version}\")\n",
    "\n",
    "print(\"\\nChecking installed packages and installing only missing/outdated ones...\")\n",
    "for requirement, dist_name, module_name, specifier in REQUIRED_PACKAGES:\n",
    "    ensure_package(requirement, dist_name, module_name, specifier)\n",
    "\n",
    "print(\"\\nDependency check complete. Restart kernel only if any package was newly installed.\")"
   ]
  },
